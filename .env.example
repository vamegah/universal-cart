# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/universal_cart"
REDIS_URL="redis://localhost:6379"

# Backend API
PORT=3001
NODE_ENV=development
AUTH_SECRET="replace-with-a-long-random-secret"
ENABLE_MOCK_PAYMENTS="false"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Stripe Issuing sandbox (for virtual cards - Phase 6)
BAAS_PROVIDER="stripe"
STRIPE_ISSUING_API_KEY="sk_test_..."
STRIPE_ISSUING_CARDHOLDER_ID="ich_..."
STRIPE_ISSUING_SANDBOX_VERIFIED_AT=""
PAYMENT_COMPLIANCE_SIGNOFF_AT=""
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# AWS (for production)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Retailer API keys (if available)
AMAZON_PA_API_KEY=""
WALMART_API_KEY=""
