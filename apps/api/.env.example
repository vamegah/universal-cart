# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: Docker Compose postgres service
# Production: inject from AWS Secrets Manager (secret name: universal-cart/DATABASE_URL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/universal_cart"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be a long random string (32+ chars). Never commit a real value.
# Production: inject from AWS Secrets Manager (secret name: universal-cart/AUTH_SECRET)
AUTH_SECRET="replace-with-a-long-random-secret"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Payments (Phase 6 – disabled until real provider is configured) ──────────
# Production: inject from AWS Secrets Manager (secret name: universal-cart/STRIPE_SECRET_KEY)
ENABLE_MOCK_PAYMENTS=false
BAAS_PROVIDER="stripe"
STRIPE_ISSUING_API_KEY="sk_test_..."
STRIPE_ISSUING_CARDHOLDER_ID="ich_..."
STRIPE_ISSUING_SANDBOX_VERIFIED_AT=2026-05-07T13:44:06.035Z
PAYMENT_COMPLIANCE_SIGNOFF_AT=""
STRIPE_SECRET_KEY="sk_test_..."

# ─── Email / SMTP alerts ──────────────────────────────────────────────────────
# Leave blank to disable email notifications (in-app audit events still fire).
# Production: inject from AWS Secrets Manager (secret name: universal-cart/SMTP_*)
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Web URL (used in alert email links) ─────────────────────────────────────
WEB_URL="http://localhost:3000"

# ─── Redis (optional – for distributed rate limiting) ────────────────────────
# Production: inject from AWS Secrets Manager or SSM Parameter Store
REDIS_URL=""

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of email addresses granted admin API access.
ADMIN_EMAILS=""

# ─── Retailer API keys (optional – enhances import quality) ──────────────────
# Production: inject from AWS Secrets Manager
AMAZON_PA_API_KEY=""
WALMART_API_KEY=""

# ─── Alert refresh schedule ───────────────────────────────────────────────────
# node-cron expression. Default: every 30 minutes.
ALERT_REFRESH_CRON="*/30 * * * *"

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL: error | warn | info | debug  (default: info)
LOG_LEVEL="info"
# LOG_TO_FILE: true | false  (default: false in production, true in development)
# Set to false in containerised/ECS deployments – logs go to stdout → CloudWatch.
LOG_TO_FILE="true"
# LOG_RETENTION_DAYS: how many days to keep combined.log / error.log locally.
# Only relevant when LOG_TO_FILE=true.
LOG_RETENTION_DAYS=7
