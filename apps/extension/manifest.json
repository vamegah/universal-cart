{
  "manifest_version": 3,
  "name": "Universal Cart",
  "version": "0.1.0",
  "description": "Add products from any store to your Universal Cart",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["product-detection.js", "content-script.js"],
      "run_at": "document_end"
    }
  ]
}
